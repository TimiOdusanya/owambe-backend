# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================
NODE_ENV=development
PORT=4001
MONGO_URI=

JWT_SECRET=
JWT_EXPIRES=2d

FRONTEND_URL_DEV=http://localhost:5174
DASHBOARD_URL_DEV=http://localhost:5173
BACKEND_URL_DEV=http://localhost:4001

# =============================================================================
# PRODUCTION (Easypanel) — copy these to your prod backend environment
# =============================================================================
# NODE_ENV=production
# PORT=8081
# PROD_MONGO_URI=
#
# Backend API
# BACKEND_URL=https://owambe-owambe-backend.meadil.easypanel.host
# BACKEND_URL_PROD=https://owambe-owambe-backend.meadil.easypanel.host
#
# Guest site (QR codes, invite links, claim flow)
# FRONTEND_URL_PROD=https://app.owambe.tech
#
# Organizer dashboard (welcome emails, admin links)
# DASHBOARD_URL_PROD=https://owambe.tech
#
# Optional aliases (same values; used if set)
# FRONTEND_URL=https://app.owambe.tech
# DASHBOARD_URL=https://owambe.tech

# Flutterwave (use LIVE keys on production)
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_SECRET_HASH=

# Email
MAILJET_API_KEY=
MAILJET_API_SECRET=
SENDGRID_API_KEY=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
